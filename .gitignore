# .gitignore para proyecto WordPress usando DDEV
# Mantener la carpeta .ddev en el repositorio (contiene la configuración del entorno)

# Editor/IDE
.idea/
.vscode/

# Node / Composer / build
node_modules/

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Logs and runtime
*.log
/coverage/
/.phpunit.result.cache

# Database dumps
*.sql
*.sql.gz

# DDEV runtime artifacts (no ignorar la configuración en .ddev/)
.ddev/.ssh/
.ddev/.db/
.ddev/import-db.sql
